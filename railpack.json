{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        { "src": "package.json", "dest": "package.json" },
        { "src": "package-lock.json", "dest": "package-lock.json" },
        "npm install"
      ]
    },
    "build": {
      "inputs": [
        { "step": "install" },
        { "local": true, "include": ["."] }
      ],
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "inputs": ["...", { "step": "build", "include": ["."] }],
    "startCommand": "node backend/server/index.js"
  }
}
